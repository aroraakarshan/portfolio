---
/**
 * Animated SVG circuit board that draws itself on scroll.
 * Uses stroke-dashoffset driven by GSAP ScrollTrigger (set up in index.astro).
 */
---

<div class="circuit-container" id="circuit-svg-container" aria-hidden="true">
  <svg
    class="circuit-svg"
    id="circuit-svg"
    viewBox="0 0 800 200"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <!-- Main horizontal bus lines -->
    <path class="circuit-line" d="M0,100 L200,100 L220,60 L400,60" stroke="#3b82f6" stroke-width="1.5" />
    <path class="circuit-line" d="M0,120 L180,120 L200,140 L500,140 L520,100 L800,100" stroke="#06b6d4" stroke-width="1.5" />
    <path class="circuit-line" d="M400,60 L420,40 L600,40 L620,60 L800,60" stroke="#a855f7" stroke-width="1.5" />

    <!-- Branch lines -->
    <path class="circuit-line" d="M300,60 L300,30 L380,30" stroke="#22c55e" stroke-width="1" />
    <path class="circuit-line" d="M500,140 L500,170 L620,170 L620,140" stroke="#f59e0b" stroke-width="1" />
    <path class="circuit-line" d="M620,60 L620,20 L720,20" stroke="#3b82f6" stroke-width="1" />
    <path class="circuit-line" d="M200,100 L200,160 L340,160" stroke="#06b6d4" stroke-width="1" />

    <!-- IC / chip rectangles -->
    <rect class="circuit-chip" x="380" y="20" width="40" height="25" rx="3" stroke="#22c55e" stroke-width="1.5" />
    <rect class="circuit-chip" x="620" y="130" width="50" height="25" rx="3" stroke="#f59e0b" stroke-width="1.5" />
    <rect class="circuit-chip" x="720" y="10" width="40" height="25" rx="3" stroke="#3b82f6" stroke-width="1.5" />

    <!-- Junction nodes -->
    <circle class="circuit-node" cx="200" cy="100" r="3" fill="#3b82f6" />
    <circle class="circuit-node" cx="400" cy="60" r="3" fill="#a855f7" />
    <circle class="circuit-node" cx="500" cy="140" r="3" fill="#f59e0b" />
    <circle class="circuit-node" cx="620" cy="60" r="3" fill="#a855f7" />
    <circle class="circuit-node" cx="300" cy="60" r="3" fill="#22c55e" />
    <circle class="circuit-node" cx="200" cy="120" r="3" fill="#06b6d4" />
    <circle class="circuit-node" cx="520" cy="100" r="3" fill="#06b6d4" />
    <circle class="circuit-node" cx="620" cy="140" r="3" fill="#f59e0b" />

    <!-- Tiny component symbols (resistor/capacitor shapes) -->
    <path class="circuit-line" d="M340,160 L350,155 L360,165 L370,155 L380,165 L390,160 L420,160" stroke="#06b6d4" stroke-width="1" />
    <line class="circuit-line" x1="420" y1="155" x2="420" y2="165" stroke="#06b6d4" stroke-width="1.5" />
    <line class="circuit-line" x1="425" y1="157" x2="425" y2="163" stroke="#06b6d4" stroke-width="1.5" />
  </svg>
</div>

<style>
  .circuit-container {
    width: 100%;
    max-width: 900px;
    margin: 2rem auto;
    padding: 1rem 2rem;
    opacity: 0.7;
    pointer-events: none;
  }

  .circuit-svg {
    width: 100%;
    height: auto;
  }

  .circuit-line,
  .circuit-chip {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    /* Initial hidden state — JS will set dasharray/dashoffset from getTotalLength() */
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
  }

  .circuit-node {
    opacity: 0;
    transform-origin: center;
    transform: scale(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .circuit-line,
    .circuit-chip {
      stroke-dasharray: none;
      stroke-dashoffset: 0;
    }
    .circuit-node {
      opacity: 0.6;
      transform: scale(1);
    }
  }
</style>
