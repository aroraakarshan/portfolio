---
import WaveDivider from '../components/WaveDivider.astro';
import '../styles/global.css';
import data from '../data/portfolio.json';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site).toString();
const ogImageSquare = new URL('/og-image-square.png', Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name,
  jobTitle: data.title,
  description: data.heroDescription,
  url: Astro.site?.toString(),
  image: ogImage,
  sameAs: [data.social.linkedin, data.social.github],
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{data.name} — {data.title}</title>
  <meta name="description" content={data.heroDescription} />
  <meta name="author" content={data.name} />
  <meta name="theme-color" content="#060a13" />
  <link rel="icon" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL.toString()} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={data.name} />
  <meta property="og:title" content={`${data.name} — ${data.title}`} />
  <meta property="og:description" content={data.heroDescription} />
  <meta property="og:url" content={canonicalURL.toString()} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`${data.name} — ${data.title}`} />
  <!-- Square variant for WhatsApp/iMessage/Telegram -->
  <meta property="og:image" content={ogImageSquare} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="1200" />
  <meta property="og:image:alt" content={`${data.name} — ${data.title}`} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${data.name} — ${data.title}`} />
  <meta name="twitter:description" content={data.heroDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <!-- Skip link for keyboard users -->
  <a href="#hero" class="skip-link">Skip to main content</a>

  <!-- Custom Cursor (hidden via CSS on touch + reduced motion) -->
  <div class="cursor" id="cursor" aria-hidden="true"></div>
  <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>

  <!-- Particles (vanilla TS, no React runtime) -->
  <canvas id="particle-canvas" aria-hidden="true"
    style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0"></canvas>

  <!-- Loading Screen -->
  <div class="loader" id="loader" aria-hidden="true">
    <div class="loader-text">
      {data.name.split('').map((char: string) => <span>{char === ' ' ? '\u00A0' : char}</span>)}
    </div>
    <div class="loader-line"></div>
  </div>

  <!-- Scroll Progress Bar -->
  <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>

  <!-- Nav -->
  <nav class="nav" id="nav">
    <a href="/" class="nav-brand">
      <div class="nav-dot"></div>
      <span>{data.name}</span>
    </a>
    <div class="nav-links" id="nav-links">
      <a href="#about" data-scramble>About</a>
      <a href="#experience" data-scramble>Experience</a>
      <a href="#projects" data-scramble>Projects</a>
      <a href="#services" data-scramble>Mentorship</a>
      <a href="#contact" data-scramble>Contact</a>
      <a href={data.social.linkedin} target="_blank" rel="noopener" data-scramble>LinkedIn</a>
      <a href={data.services.bookingLink} target="_blank" rel="noopener" class="nav-cta">🎯 Book a Session</a>
    </div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- ═══════ HERO ═══════ -->
  <section class="hero" id="hero" tabindex="-1">
    <p class="hero-label" id="hero-label">{data.tagline}</p>
    <h1 class="hero-title" id="hero-title">
      {data.heroHeadline.lines.map((line: any) => (
        <span class="line">
          {line.words.map((word: string) => (
            <span class="word">
              <span class={`word-inner ${line.gradient ? 'gradient-text' : ''}`}>{word}</span>
            </span>
          ))}
        </span>
      ))}
    </h1>
    <p class="hero-sub" id="hero-sub">{data.heroDescription}</p>
    <div class="hero-cta" id="hero-cta">
      {data.heroCTAs.map((cta: any) => (
        <a
          href={cta.href}
          class={`btn btn-${cta.style}`}
          {...(cta.external ? { target: '_blank', rel: 'noopener' } : {})}
        >{cta.label}</a>
      ))}
    </div>
    <div class="hero-scroll" id="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-bar"></div>
    </div>
  </section>

  <WaveDivider color="#3b82f6" />

  <!-- ═══════ MARQUEE ═══════ -->
  <div class="marquee">
    <div class="marquee-track" id="marquee-track">
      {[...data.marqueeItems, ...data.marqueeItems].map((item: string, i: number) => (
        <Fragment key={i}>
          <span class="marquee-item">{item}</span>
          <span class="marquee-item marquee-dot">·</span>
        </Fragment>
      ))}
    </div>
  </div>

  <!-- ═══════ ABOUT ═══════ -->
  <section class="section" id="about">
    <div class="section-inner">
      <div class="about-layout">
        <div>
          <p class="section-label" data-reveal>About</p>
          <h2 class="section-title" data-reveal set:html={data.about.headline.replace(/\n/g, '<br/>')} />
          <p class="section-desc" data-reveal set:html={data.about.description} />
        </div>
        <div class="about-stats">
          {data.about.skills.map((skill: any) => (
            <div class="stat" data-reveal>
              <div class="stat-value" style={`color: var(--accent-${skill.color});`}>{skill.label}</div>
              <div class="stat-label">{skill.detail}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <WaveDivider color="#a855f7" flip />

  <!-- ═══════ EXPERIENCE ═══════ -->
  <section class="section" id="experience">
    <div class="section-inner">
      <p class="section-label" data-reveal>Experience</p>
      <h2 class="section-title" data-reveal>Career Timeline</h2>

      <div class="timeline">
        {data.experience.map((job: any, i: number) => (
          <div class="timeline-item" data-reveal>
            <div class="timeline-dot"></div>
            <div class="timeline-date">{job.date}</div>
            <div class="timeline-role">{job.role}</div>
            <div class="timeline-company">{job.company}</div>
            <div class="timeline-highlights">
              {job.highlights.map((chip: any) => (
                <span class={`timeline-chip ${chip.featured ? 'chip-highlight' : ''}`}>{chip.label}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════ IMPACT NUMBERS ═══════ -->
  <section class="section section--impact" id="impact">
    <div class="section-inner">
      <p class="section-label" data-reveal>Impact</p>
      <h2 class="section-title" data-reveal>Numbers That Speak</h2>
      <div class="impact-grid">
        <div class="impact-card" data-reveal>
          <span class="impact-number" data-count="10">0</span><span class="impact-suffix">+</span>
          <span class="impact-label">Years in VLSI Power Integrity</span>
        </div>
        <div class="impact-card" data-reveal>
          <span class="impact-number" data-count="50">0</span><span class="impact-suffix">%</span>
          <span class="impact-label">Runtime Reduction Achieved</span>
        </div>
        <div class="impact-card" data-reveal>
          <span class="impact-number" data-count="1" data-decimals="0">0</span><span class="impact-suffix">B+</span>
          <span class="impact-label">Data Points Compared</span>
        </div>
        <div class="impact-card" data-reveal>
          <span class="impact-number" data-count="23">0</span><span class="impact-suffix">M</span>
          <span class="impact-label">Net Segments Analyzed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ PROJECTS ═══════ -->
  <section class="section section--hscroll" id="projects">
    <div class="section-inner">
      <p class="section-label" data-reveal>Open Source</p>
      <h2 class="section-title" data-reveal>Side Projects and Learning Tools</h2>
      <p class="section-desc" data-reveal style="margin-bottom: 1rem; max-width: 700px;">
        {data.projects.description}
      </p>
      <a href={data.projects.suiteLink} target="_blank" rel="noopener" class="project-suite-link" data-reveal>
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="18" height="18"><rect x="2" y="4" width="20" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.8"/><rect x="2" y="13" width="20" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.8"/><line x1="7" y1="11" x2="7" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="11" x2="12" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="17" y1="11" x2="17" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        {data.projects.suiteLabel} →
      </a>

      <div class="project-showcase" id="project-showcase" data-reveal>
        {data.projects.items.map((project: any) => (
          <a href={project.href} target="_blank" rel="noopener" class="project-card">
            <div class="project-visual">
              <div class="browser-chrome">
                <div class="browser-dots">
                  <span style="background:#ff5f57"></span>
                  <span style="background:#febc2e"></span>
                  <span style="background:#28c840"></span>
                </div>
                <div class="browser-url">{project.browserUrl}</div>
              </div>
              <div class="browser-content">
                <div class="project-preview" data-clip-reveal>
                  {project.name === 'PDN SPR Visualizer' ? (
                    <svg class="project-svg" viewBox="0 0 504 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <!-- 3D grid representing power delivery network -->
                      <defs>
                        <linearGradient id="grid-grad-spr" x1="0" y1="0" x2="504" y2="220">
                          <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.6" />
                          <stop offset="100%" stop-color="#22c55e" stop-opacity="0.4" />
                        </linearGradient>
                      </defs>
                      <!-- Horizontal grid lines -->
                      <line x1="40" y1="60" x2="464" y2="60" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <line x1="40" y1="100" x2="464" y2="100" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <line x1="40" y1="140" x2="464" y2="140" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <line x1="40" y1="180" x2="464" y2="180" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <!-- Vertical grid lines -->
                      <line x1="100" y1="40" x2="100" y2="200" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <line x1="190" y1="40" x2="190" y2="200" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <line x1="280" y1="40" x2="280" y2="200" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <line x1="370" y1="40" x2="370" y2="200" stroke="url(#grid-grad-spr)" stroke-width="0.8" class="grid-line" />
                      <!-- Shortest path highlight -->
                      <path d="M100,180 L100,140 L190,140 L190,100 L280,100 L370,100 L370,60" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" class="spr-path" fill="none" />
                      <!-- Nodes -->
                      <circle cx="100" cy="180" r="4" fill="#3b82f6" class="spr-node" />
                      <circle cx="100" cy="140" r="3" fill="#06b6d4" class="spr-node" />
                      <circle cx="190" cy="140" r="3" fill="#06b6d4" class="spr-node" />
                      <circle cx="190" cy="100" r="3" fill="#06b6d4" class="spr-node" />
                      <circle cx="280" cy="100" r="3" fill="#06b6d4" class="spr-node" />
                      <circle cx="370" cy="100" r="3" fill="#06b6d4" class="spr-node" />
                      <circle cx="370" cy="60" r="4" fill="#22c55e" class="spr-node" />
                      <!-- Labels -->
                      <text x="90" y="205" fill="#3b82f6" font-size="10" font-family="monospace" opacity="0.7">SRC</text>
                      <text x="360" y="50" fill="#22c55e" font-size="10" font-family="monospace" opacity="0.7">DST</text>
                    </svg>
                  ) : (
                    <svg class="project-svg" viewBox="0 0 504 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <!-- IR Drop voltage waveform visualization -->
                      <!-- VDD rail at top -->
                      <line x1="40" y1="40" x2="470" y2="40" stroke="#22c55e" stroke-width="0.5" stroke-dasharray="4 3" opacity="0.4" />
                      <text x="12" y="44" fill="#22c55e" font-size="9" font-family="monospace" opacity="0.7">VDD</text>
                      <!-- VDD drooping waveform -->
                      <path class="vdd-wave" d="M40,40 C70,40 80,42 100,50 C120,58 130,44 160,48 C190,52 200,65 230,70 C260,75 270,55 300,52 C330,49 350,60 380,56 C410,52 430,44 470,42" stroke="#22c55e" stroke-width="2" stroke-linecap="round" fill="none" />
                      <!-- IR drop shaded region -->
                      <path d="M40,40 C70,40 80,42 100,50 C120,58 130,44 160,48 C190,52 200,65 230,70 C260,75 270,55 300,52 C330,49 350,60 380,56 C410,52 430,44 470,42 L470,40 L40,40 Z" fill="#22c55e" opacity="0.06" />

                      <!-- VSS rail at bottom -->
                      <line x1="40" y1="180" x2="470" y2="180" stroke="#3b82f6" stroke-width="0.5" stroke-dasharray="4 3" opacity="0.4" />
                      <text x="12" y="184" fill="#3b82f6" font-size="9" font-family="monospace" opacity="0.7">VSS</text>
                      <!-- VSS bounce waveform -->
                      <path class="vss-wave" d="M40,180 C60,180 80,178 100,172 C120,166 140,175 160,170 C180,165 200,155 230,150 C260,145 280,162 300,166 C320,170 350,160 380,164 C410,168 440,176 470,178" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" fill="none" />
                      <!-- Ground bounce shaded region -->
                      <path d="M40,180 C60,180 80,178 100,172 C120,166 140,175 160,170 C180,165 200,155 230,150 C260,145 280,162 300,166 C320,170 350,160 380,164 C410,168 440,176 470,178 L470,180 L40,180 Z" fill="#3b82f6" opacity="0.06" />

                      <!-- Worst IR drop annotation -->
                      <line x1="230" y1="70" x2="230" y2="40" stroke="#ef4444" stroke-width="1" stroke-dasharray="3 2" opacity="0.6" />
                      <text x="236" y="58" fill="#ef4444" font-size="8" font-family="monospace" opacity="0.7">IR drop</text>

                      <!-- Worst ground bounce annotation -->
                      <line x1="230" y1="150" x2="230" y2="180" stroke="#f59e0b" stroke-width="1" stroke-dasharray="3 2" opacity="0.6" />
                      <text x="236" y="168" fill="#f59e0b" font-size="8" font-family="monospace" opacity="0.7">GND bounce</text>

                      <!-- Time axis -->
                      <line x1="40" y1="200" x2="470" y2="200" stroke="rgba(148,163,184,0.3)" stroke-width="0.5" />
                      <text x="240" y="214" fill="rgba(148,163,184,0.4)" font-size="8" font-family="monospace" text-anchor="middle">time →</text>
                    </svg>
                  )}
                </div>
              </div>
            </div>
            <div class="project-info">
              <div class="project-tags">
                {project.tags.map((tag: any) => (
                  <span class={`tag tag-${tag.color}`}>{tag.label}</span>
                ))}
              </div>
              <h3 class="project-name">{project.name}</h3>
              <p class="project-desc">{project.description}</p>
              <span class="project-link">Launch Tool →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <WaveDivider color="#06b6d4" />

  <!-- ═══════ CONTENT ═══════ -->
  <section class="section" id="content">
    <div class="section-inner">
      <p class="section-label" data-reveal>Content</p>
      <h2 class="section-title" data-reveal>Videos and Posts</h2>
      <p class="section-desc" data-reveal>{data.content.description}</p>

      <div class="content-list" data-reveal>
        {data.content.posts.map((post: any, i: number) => {
          const postUrl = post.embed.replace('/embed/feed/update/', '/feed/update/').split('?')[0];
          return (
            <a href={postUrl} target="_blank" rel="noopener" class="content-row">
              <span class="content-row-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="content-row-title">{post.title}</span>
              <span class="content-row-tag">{post.tag}</span>
              <span class="content-row-arrow">→</span>
            </a>
          );
        })}
      </div>

      <div style="margin-top: 2.5rem;" data-reveal>
        <a href={data.content.linkedinUrl} target="_blank" rel="noopener" class="btn btn-ghost">💼 All Posts on LinkedIn →</a>
      </div>
    </div>
  </section>

  <!-- ═══════ WORK WITH ME ═══════ -->
  <section class="section" id="services">
    <div class="section-inner">
      <p class="section-label" data-reveal>Work With Me</p>
      <h2 class="section-title" data-reveal>Mentorship</h2>

      <div class="mentor-hero" data-reveal>
        <div class="mentor-stats">
          <div class="mentor-stat">
            <span class="mentor-stat-value">4.7<span class="mentor-stat-unit">/5</span></span>
            <span class="mentor-stat-label">Rating</span>
          </div>
          <div class="mentor-stat">
            <span class="mentor-stat-value">40+</span>
            <span class="mentor-stat-label">Sessions</span>
          </div>
          <div class="mentor-stat">
            <span class="mentor-stat-value">30</span>
            <span class="mentor-stat-label">Testimonials</span>
          </div>
        </div>
        <div class="content-list mentor-list">
          {data.services.items.map((service: any, i: number) => (
            <a href={data.services.bookingLink} target="_blank" rel="noopener" class="content-row">
              <span class="content-row-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="content-row-title">{service.title}</span>
              <span class="content-row-desc">{service.description}</span>
              <span class="content-row-arrow">→</span>
            </a>
          ))}
        </div>
        <a href={data.services.bookingLink} target="_blank" rel="noopener" class="btn btn-primary" style="align-self: flex-start; margin-top: 0.5rem;">🎯 Book a Session →</a>
      </div>

      <!-- Testimonials -->
      <div class="testimonials" data-reveal>
        <div class="testimonial-track" id="testimonial-track">
          {[...data.testimonials, ...data.testimonials].map((text: string) => (
            <div class="testimonial">
              <p>"{text}"</p>
              <span class="testimonial-rating">★★★★★</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CONTACT ═══════ -->
  <section class="section section--contact" id="contact">
    <div class="section-inner contact-inner">
      <p class="section-label" data-reveal>Contact</p>
      <h2 class="contact-headline" data-reveal>Let's build<br/>something together.</h2>
      <p class="section-desc" data-reveal style="max-width: 480px;">
        Interested in VLSI tools, interactive education, or collaboration? I'd love to hear from you.
      </p>
      <div class="contact-chips" data-reveal>
        <a href={data.services.bookingLink} target="_blank" rel="noopener" class="chip chip-primary">🎯 Book a Session</a>
        <a href={data.social.github} target="_blank" rel="noopener" class="chip">⚡ GitHub</a>
        <a href={data.social.linkedin} target="_blank" rel="noopener" class="chip">💼 LinkedIn</a>
      </div>
    </div>
  </section>

  <!-- ═══════ FOOTER ═══════ -->
  <footer class="footer">
    <div class="footer-left">
      <span class="footer-name">Akarshan Arora</span>
      <span class="footer-sep">·</span>
      <span class="footer-role">VLSI EMIR CAD Engineer</span>
    </div>
    <div class="footer-right">
      <span>© 2026</span>
      <span class="footer-sep">·</span>
      <span>Designed & built from scratch with AI</span>
    </div>
  </footer>

  <!-- ═══════ GSAP + LENIS ANIMATIONS ═══════ -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from '@studio-freight/lenis';
    import { initParticleCanvas } from '../scripts/particleCanvas';

    // Always init the particle canvas (it respects reduced-motion internally).
    const canvasEl = document.getElementById('particle-canvas') as HTMLCanvasElement | null;
    if (canvasEl) initParticleCanvas(canvasEl);

    const prefersReducedMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      const l = document.getElementById('loader');
      if (l) l.style.display = 'none';
    } else {
      gsap.registerPlugin(ScrollTrigger);

    // ═══════════════════════════════════════
    // 1. SMOOTH SCROLL (Lenis)
    // ═══════════════════════════════════════
    const lenis = new Lenis({
      duration: 1.4,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);

    // ═══════════════════════════════════════
    // 2. CUSTOM CURSOR + MAGNETIC EFFECT
    // ═══════════════════════════════════════
    const cursor = document.getElementById('cursor');
    const cursorDot = document.getElementById('cursor-dot');
    let cx = -100, cy = -100, dx = -100, dy = -100;

    document.addEventListener('mousemove', (e) => {
      cx = e.clientX;
      cy = e.clientY;
      gsap.to(cursorDot, { x: cx, y: cy, duration: 0.08, ease: 'power2.out' });
    });

    gsap.ticker.add(() => {
      dx += (cx - dx) * 0.1;
      dy += (cy - dy) * 0.1;
      gsap.set(cursor, { x: dx, y: dy });
    });

    document.querySelectorAll('a, button, .btn, .chip, .stat, .project-card, .mentor-topic, .timeline-item, .content-row, .impact-card').forEach((el) => {
      el.addEventListener('mouseenter', () => cursor.classList.add('hovering'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('hovering'));
    });

    document.querySelectorAll('.btn, .chip').forEach((btn) => {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const bx = rect.left + rect.width / 2;
        const by = rect.top + rect.height / 2;
        const pullX = (e.clientX - bx) * 0.2;
        const pullY = (e.clientY - by) * 0.2;
        gsap.to(btn, { x: pullX, y: pullY, duration: 0.4, ease: 'power3.out' });
      });
      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1, 0.4)' });
      });
    });

    // ═══════════════════════════════════════
    // 3. LOADING SCREEN → chains into hero
    // ═══════════════════════════════════════
    const loader = document.getElementById('loader');
    const loaderChars = loader.querySelectorAll('.loader-text span');
    const lineEl = loader.querySelector('.loader-line');

    const masterTl = gsap.timeline();

    // Loader sequence
    masterTl
      .set(loaderChars, { y: '120%', rotateX: -80 })
      .to(loaderChars, {
        y: '0%',
        rotateX: 0,
        duration: 0.7,
        stagger: 0.03,
        ease: 'power4.out',
      })
      .fromTo(lineEl,
        { scaleX: 0 },
        { scaleX: 1, duration: 0.6, ease: 'power2.inOut', transformOrigin: 'left center' },
        '-=0.2'
      )
      .to(loaderChars, {
        y: '-120%',
        rotateX: 80,
        duration: 0.4,
        stagger: 0.02,
        ease: 'power3.in',
      }, '+=0.3')
      .to(lineEl, { scaleX: 0, duration: 0.25, transformOrigin: 'right center' }, '-=0.25')
      .to(loader, {
        clipPath: 'inset(0 0 100% 0)',
        duration: 0.8,
        ease: 'power4.inOut',
      })
      .set(loader, { display: 'none' });

    // Hero reveal — chains directly off loader (no fixed delay)
    masterTl
      .to('#nav', { opacity: 1, duration: 0.8, ease: 'power2.out' }, '-=0.4')
      .fromTo('#hero-label',
        { opacity: 0, y: 20, scale: 0.95 },
        { opacity: 1, y: 0, scale: 1, duration: 0.7, ease: 'power3.out' },
        '-=0.5'
      )
      .to('.word-inner', {
        y: '0%',
        duration: 1.2,
        stagger: 0.06,
        ease: 'power4.out',
      }, '-=0.4')
      .fromTo('#hero-sub',
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' },
        '-=0.6'
      )
      .fromTo('#hero-cta',
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' },
        '-=0.5'
      )
      .fromTo('#hero-scroll',
        { opacity: 0 },
        { opacity: 1, duration: 0.6 },
        '-=0.2'
      );

    // ═══════════════════════════════════════
    // 4. HERO PARALLAX on scroll
    // ═══════════════════════════════════════
    gsap.fromTo('#hero-label',
      { yPercent: 0, opacity: 1 },
      {
        yPercent: -50, opacity: 0,
        immediateRender: false,
        scrollTrigger: { trigger: '#hero', start: 'top top', end: '60% top', scrub: 0.8 }
      }
    );
    gsap.fromTo('#hero-title',
      { yPercent: 0, scale: 1, opacity: 1 },
      {
        yPercent: -40, scale: 0.92, opacity: 0,
        immediateRender: false,
        scrollTrigger: { trigger: '#hero', start: 'top top', end: '80% top', scrub: 0.8 }
      }
    );
    gsap.fromTo('#hero-sub',
      { yPercent: 0, opacity: 1 },
      {
        yPercent: -30, opacity: 0,
        immediateRender: false,
        scrollTrigger: { trigger: '#hero', start: '20% top', end: '70% top', scrub: 0.8 }
      }
    );
    gsap.fromTo('#hero-cta',
      { yPercent: 0, opacity: 1 },
      {
        yPercent: -20, opacity: 0,
        immediateRender: false,
        scrollTrigger: { trigger: '#hero', start: '30% top', end: '70% top', scrub: 0.8 }
      }
    );
    gsap.fromTo('#hero-scroll',
      { opacity: 1 },
      {
        opacity: 0,
        immediateRender: false,
        scrollTrigger: { trigger: '#hero', start: '10% top', end: '30% top', scrub: true }
      }
    );

    // ═══════════════════════════════════════
    // 5. MARQUEE - scroll-speed reactive
    // ═══════════════════════════════════════
    const track = document.getElementById('marquee-track');
    const trackWidth = track.scrollWidth / 2;
    const marqueeAnim = gsap.to(track, {
      x: -trackWidth,
      duration: 25,
      ease: 'none',
      repeat: -1,
    });
    ScrollTrigger.create({
      trigger: '.marquee',
      start: 'top bottom',
      end: 'bottom top',
      onUpdate: (self) => {
        const speed = 1 + Math.abs(self.getVelocity() / 3000);
        gsap.to(marqueeAnim, { timeScale: speed, duration: 0.3, overwrite: true });
      }
    });

    // ═══════════════════════════════════════
    // 6. SECTION REVEALS - clip + transform
    // ═══════════════════════════════════════
    document.querySelectorAll('.section-label').forEach((el) => {
      gsap.fromTo(el,
        { x: -30, opacity: 0 },
        {
          x: 0, opacity: 1, duration: 0.8, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%' },
        }
      );
    });

    document.querySelectorAll('.section-title, .contact-headline').forEach((title) => {
      const text = title.innerHTML;
      title.innerHTML = text.replace(/(<[^>]+>)|(.)/g, (match, tag, char) => {
        if (tag) return tag;
        if (char === ' ') return ' ';
        return `<span class="char" style="display:inline-block;opacity:0;transform:translateY(30px)">${char}</span>`;
      });
      const chars = title.querySelectorAll('.char');
      gsap.to(chars, {
        y: 0, opacity: 1, duration: 0.5, stagger: 0.015, ease: 'power3.out',
        scrollTrigger: { trigger: title, start: 'top 85%' },
      });
    });

    document.querySelectorAll('.section-desc').forEach((el) => {
      gsap.fromTo(el,
        { y: 40, opacity: 0 },
        {
          y: 0, opacity: 1, duration: 1, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 85%' },
        }
      );
    });

    // ═══════════════════════════════════════
    // 7. ABOUT STATS - counter + scale entrance
    // ═══════════════════════════════════════
    document.querySelectorAll('.stat').forEach((stat, i) => {
      gsap.fromTo(stat,
        { y: 60, opacity: 0, scale: 0.9 },
        {
          y: 0, opacity: 1, scale: 1,
          duration: 0.8,
          ease: 'back.out(1.4)',
          delay: i * 0.1,
          scrollTrigger: { trigger: '.about-stats', start: 'top 82%' },
        }
      );
    });

    // ═══════════════════════════════════════
    // 9. EXPERIENCE TIMELINE
    // ═══════════════════════════════════════
    const timeline = document.querySelector('.timeline');
    if (timeline) {
      gsap.fromTo(timeline,
        { '--line-progress': '0%' },
        {
          '--line-progress': '100%',
          ease: 'none',
          scrollTrigger: {
            trigger: timeline,
            start: 'top 70%',
            end: 'bottom 50%',
            scrub: 0.5,
          }
        }
      );

      document.querySelectorAll('.timeline-item').forEach((item, i) => {
        gsap.fromTo(item,
          { x: -60, opacity: 0, rotateY: -5 },
          {
            x: 0, opacity: 1, rotateY: 0,
            duration: 0.9,
            ease: 'power3.out',
            delay: i * 0.12,
            scrollTrigger: { trigger: item, start: 'top 85%' },
          }
        );

        const dot = item.querySelector('.timeline-dot');
        gsap.fromTo(dot,
          { scale: 0 },
          {
            scale: 1,
            duration: 0.5,
            ease: 'elastic.out(1.2, 0.5)',
            delay: i * 0.12 + 0.3,
            scrollTrigger: { trigger: item, start: 'top 85%' },
          }
        );

        const chips = item.querySelectorAll('.timeline-chip');
        gsap.fromTo(chips,
          { y: 10, opacity: 0, scale: 0.9 },
          {
            y: 0, opacity: 1, scale: 1,
            duration: 0.4,
            stagger: 0.05,
            ease: 'power3.out',
            delay: i * 0.12 + 0.5,
            scrollTrigger: { trigger: item, start: 'top 85%' },
          }
        );
      });
    }

    // ═══════════════════════════════════════
    // 10. IMPACT NUMBERS — animated counters
    // ═══════════════════════════════════════
    document.querySelectorAll('.impact-card').forEach((card, i) => {
      gsap.fromTo(card,
        { y: 80, opacity: 0, scale: 0.85 },
        {
          y: 0, opacity: 1, scale: 1,
          duration: 1,
          ease: 'back.out(1.6)',
          delay: i * 0.12,
          scrollTrigger: { trigger: '.impact-grid', start: 'top 82%' },
        }
      );

      const numEl = card.querySelector('.impact-number') as HTMLElement;
      if (numEl) {
        const target = parseFloat(numEl.dataset.count || '0');
        const obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 2,
          ease: 'power2.out',
          delay: i * 0.15 + 0.3,
          scrollTrigger: { trigger: '.impact-grid', start: 'top 80%' },
          onUpdate: () => {
            numEl.textContent = target >= 100 ? Math.round(obj.val).toString() : obj.val.toFixed(target < 10 ? 0 : 0).toString();
          },
        });
      }
    });

    // ═══════════════════════════════════════
    // 11. PROJECT CARDS — vertical reveal entrance
    // ═══════════════════════════════════════
    const projectShowcase = document.getElementById('project-showcase');
    if (projectShowcase) {
      const cards = projectShowcase.querySelectorAll('.project-card');
      cards.forEach((card, i) => {
        gsap.fromTo(card,
          { y: 80, opacity: 0, scale: 0.94 },
          {
            y: 0, opacity: 1, scale: 1,
            duration: 1,
            delay: i * 0.15,
            ease: 'power3.out',
            scrollTrigger: { trigger: card, start: 'top 88%' },
          }
        );

        gsap.fromTo(card.querySelectorAll('.project-tags .tag'),
          { y: 12, opacity: 0, scale: 0.85 },
          {
            y: 0, opacity: 1, scale: 1,
            duration: 0.5,
            stagger: 0.06,
            ease: 'back.out(2)',
            scrollTrigger: { trigger: card, start: 'top 78%' },
          }
        );
      });
    }

    // 3D tilt on project cards (desktop only)
    if (window.innerWidth > 768) {
      document.querySelectorAll('.project-card').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;  // -0.5 to 0.5
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          gsap.to(card, {
            rotateY: x * 8,
            rotateX: -y * 6,
            y: -6,
            duration: 0.4,
            ease: 'power2.out',
            overwrite: 'auto',
          });
        });
        card.addEventListener('mouseleave', () => {
          gsap.to(card, {
            rotateY: 0,
            rotateX: 0,
            y: 0,
            duration: 0.6,
            ease: 'elastic.out(1, 0.5)',
            overwrite: 'auto',
          });
        });
      });
    }

    // ═══════════════════════════════════════
    // 12. CONTENT ROWS — stagger slide-in
    // ═══════════════════════════════════════
    document.querySelectorAll('.content-row').forEach((row, i) => {
      gsap.fromTo(row,
        { x: -40, opacity: 0 },
        {
          x: 0, opacity: 1,
          duration: 0.6,
          ease: 'power3.out',
          delay: i * 0.08,
          scrollTrigger: { trigger: '.content-list', start: 'top 85%' },
        }
      );
    });

    // ═══════════════════════════════════════
    // 13. MENTORSHIP — stats + topics
    // ═══════════════════════════════════════
    document.querySelectorAll('.mentor-stat').forEach((stat, i) => {
      gsap.fromTo(stat,
        { y: 30, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.7,
          ease: 'power3.out',
          delay: i * 0.1,
          scrollTrigger: { trigger: '.mentor-stats', start: 'top 85%' },
        }
      );
    });
    document.querySelectorAll('.mentor-list .content-row').forEach((row, i) => {
      gsap.fromTo(row,
        { x: -40, opacity: 0 },
        {
          x: 0, opacity: 1,
          duration: 0.6,
          ease: 'power3.out',
          delay: i * 0.08,
          scrollTrigger: { trigger: '.mentor-list', start: 'top 85%' },
        }
      );
    });

    // ═══════════════════════════════════════
    // 14. TESTIMONIALS - auto-scrolling loop
    // ═══════════════════════════════════════
    const testTrack = document.getElementById('testimonial-track');
    const testSection = document.querySelector('.testimonials');
    if (testTrack && testSection) {
      const testWidth = testTrack.scrollWidth / 2;
      gsap.to(testTrack, {
        x: -testWidth,
        duration: 25,
        ease: 'none',
        repeat: -1,
      });
    }

    // ═══════════════════════════════════════
    // 15. CONTACT - chips bounce in
    // ═══════════════════════════════════════
    document.querySelectorAll('.chip').forEach((chip, i) => {
      gsap.fromTo(chip,
        { y: 30, opacity: 0, scale: 0.85 },
        {
          y: 0, opacity: 1, scale: 1,
          duration: 0.6,
          ease: 'back.out(1.8)',
          delay: i * 0.08,
          scrollTrigger: { trigger: '.contact-chips', start: 'top 85%' },
        }
      );
    });

    // ═══════════════════════════════════════
    // 16. SECTION PARALLAX (exclude projects — handled by horizontal scroll)
    // ═══════════════════════════════════════
    document.querySelectorAll('.section:not(.section--hscroll):not(.section--contact)').forEach((section) => {
      const inner = section.querySelector('.section-inner');
      if (!inner) return;
      gsap.fromTo(inner,
        { yPercent: 5 },
        {
          yPercent: -5,
          ease: 'none',
          scrollTrigger: {
            trigger: section,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 0.4,
          }
        }
      );
    });

    // ═══════════════════════════════════════
    // 17. SCROLL PROGRESS BAR
    // ═══════════════════════════════════════
    const progressBar = document.getElementById('scroll-progress');
    if (progressBar) {
      gsap.to(progressBar, {
        width: '100%',
        ease: 'none',
        scrollTrigger: {
          trigger: document.documentElement,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.3,
        },
      });
    }

    // ═══════════════════════════════════════
    // 18. TEXT SCRAMBLE on nav hover
    // ═══════════════════════════════════════
    const scrambleChars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%&*';
    document.querySelectorAll('[data-scramble]').forEach((el) => {
      const original = el.textContent || '';
      let frameId: number;
      el.addEventListener('mouseenter', () => {
        let iteration = 0;
        cancelAnimationFrame(frameId);
        const scramble = () => {
          el.textContent = original
            .split('')
            .map((char, i) => {
              if (i < iteration) return original[i];
              return scrambleChars[Math.floor(Math.random() * scrambleChars.length)];
            })
            .join('');
          if (iteration < original.length) {
            iteration += 1 / 2;
            frameId = requestAnimationFrame(scramble);
          }
        };
        scramble();
      });
      el.addEventListener('mouseleave', () => {
        cancelAnimationFrame(frameId);
        el.textContent = original;
      });
    });

    // ═══════════════════════════════════════
    // 19. PROJECT SVG ANIMATIONS
    // ═══════════════════════════════════════
    function animateSvgDraw(path: SVGPathElement, trigger: Element, delayVal: number, duration: number) {
      const len = path.getTotalLength();
      gsap.fromTo(path,
        { strokeDasharray: len, strokeDashoffset: len },
        {
          strokeDashoffset: 0,
          duration,
          delay: delayVal,
          ease: 'power2.inOut',
          scrollTrigger: { trigger, start: 'top 88%' },
        }
      );
    }

    const sprPath = document.querySelector('.spr-path') as SVGPathElement;
    const sprCard = sprPath?.closest('.project-card');
    if (sprPath && sprCard) {
      animateSvgDraw(sprPath, sprCard, 0.2, 1.5);
    }

    const sprNodes = document.querySelectorAll('.spr-node');
    const sprNodeCard = sprNodes[0]?.closest('.project-card');
    if (sprNodes.length && sprNodeCard) {
      gsap.fromTo(sprNodes,
        { opacity: 0, scale: 0, transformOrigin: 'center' },
        {
          opacity: 1, scale: 1,
          duration: 0.4,
          stagger: 0.06,
          ease: 'back.out(2)',
          scrollTrigger: { trigger: sprNodeCard, start: 'top 88%' },
          delay: 0.8,
        }
      );
    }

    const vddWave = document.querySelector('.vdd-wave') as SVGPathElement;
    const vssWave = document.querySelector('.vss-wave') as SVGPathElement;
    [vddWave, vssWave].forEach((wave) => {
      if (!wave) return;
      const waveCard = wave.closest('.project-card');
      if (waveCard) animateSvgDraw(wave, waveCard, 0.2, 1.5);
    });

    // ═══════════════════════════════════════
    // 20. MOBILE NAV
    // ═══════════════════════════════════════
    const hamburger = document.getElementById('nav-hamburger');
    const navLinks = document.getElementById('nav-links');
    if (hamburger && navLinks) {
      const toggleNav = () => {
        const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
        hamburger.setAttribute('aria-expanded', String(!isOpen));
        navLinks.classList.toggle('nav-links--open');
        hamburger.classList.toggle('nav-hamburger--open');
      };

      hamburger.addEventListener('click', toggleNav);

      // Close on link click
      navLinks.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          if (navLinks.classList.contains('nav-links--open')) toggleNav();
        });
      });

      // Close on ESC
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && navLinks.classList.contains('nav-links--open')) toggleNav();
      });
    }

    } // end else (prefers-reduced-motion guard)
  </script>
</body>
</html>
